{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "cssPriority": "user",
  "control-center-margin-top": 10,
  "control-center-margin-bottom": 0,
  "control-center-margin-right": 10,
  "control-center-margin-left": 0,
  "notification-margin-right": 5,
  "notification-margin-top": 5,
  "notification-2fa-action": true,
  "notification-inline-replies": false,
  "notification-icon-size": 24,
  "notification-body-image-height": 160,
  "notification-body-image-width": 160,
  "notification-window-width": 340,
  "timeout": 6,
  "timeout-low": 3,
  "timeout-critical": 0,
  "fit-to-screen": false,
  "control-center-width": 380,
  "control-center-height": 800,
  "keyboard-shortcuts": true,
  "image-visibility": "when available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,
  "scripts": {
    "sound-normal": {
      "exec": "pw-play /usr/share/sounds/freedesktop/stereo/message-new-instant.oga",
      "urgency": "Normal"
    },
    "sound-low": {
      "exec": "pw-play /usr/share/sounds/freedesktop/stereo/message-new-instant.oga",
      "urgency": "Low"
    },
    "sound-critical": {
      "exec": "pw-play /usr/share/sounds/freedesktop/stereo/dialog-warning.oga",
      "urgency": "Critical"
    }
  },
  "widgets": [
      "buttons-grid",
      "volume",
      "backlight",
      "mpris",
      "dnd",
      "title",
      "notifications"
  ],
  "widget-config": {
      "title": {
          "text": "Notifications",
          "clear-all-button": true,
          "button-text": "󰎟"
      },
      "backlight": {
          "label": "󰃟"
      },
      "volume": {
          "label": "󰕾"
      },
      "dnd": {
          "text": "Do Not Disturb"
      },
      "mpris": {
          "image-size": 40,
          "image-radius": 8
      },
      "buttons-grid": {
          "actions": [
              {
                  "label": "󰤨",
                  "type": "toggle",
                  "active": false,
                  "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && nmcli radio wifi on || nmcli radio wifi off'",
                  "update-command": "sh -c 'nmcli radio wifi | grep -q enabled && echo true || echo false'"
              },
              {
                  "label": "󰂯",
                  "type": "toggle",
                  "active": false,
                  "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && bluetoothctl power on || bluetoothctl power off'",
                  "update-command": "sh -c 'bluetoothctl show | grep -q \"Powered: yes\" && echo true || echo false'"
              },
              {
                  "label": "󰕾",
                  "type": "toggle",
                  "active": false,
                  "command": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
                  "update-command": "sh -c 'pactl get-sink-mute @DEFAULT_SINK@ | grep -q \"yes\" && echo false || echo true'"
              },
              {
                  "label": "󰍭",
                  "type": "toggle",
                  "active": false,
                  "command": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
                  "update-command": "sh -c 'pactl get-source-mute @DEFAULT_SOURCE@ | grep -q \"yes\" && echo true || echo false'"
              },
              {
                  "label": "󰌾",
                  "command": "hyprlock"
              },
              {
                  "label": "󰐥",
                  "command": "~/scripts/menu-system.sh"
              }
          ]
      }
  }
}
